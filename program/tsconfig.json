{
  "compilerOptions": {
    "types": ["mocha", "chai", "node"],
    "lib": ["es2019", "dom"],
    "module": "commonjs",
    "target": "es2019",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "outDir": "dist",
    "baseUrl": "."
  },
  "include": ["tests/**/*.ts"],
  "exclude": ["node_modules", "target"]
}
